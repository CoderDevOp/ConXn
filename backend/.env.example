# Optional: override CSV path (default: ../alumni.csv at repo root when present)
# ALUMNI_CSV=

# Optional: Google Gemini for explanations & email (otherwise Ollama or templates)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Local LLM (default). Install Ollama and pull a model, e.g. llama3.2
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Optional Gmail / SMTP — leave empty for demo mode
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
